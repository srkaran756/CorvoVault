# =============================================================
# CorvoVault — Environment Variables
# =============================================================
# NOTE: You do NOT need a .env file to run this application.
# All API keys and configuration are entered through the
# Settings panel inside the app and stored locally.
#
# This file exists only for reference / advanced users who
# prefer environment variables for deployment scenarios.
# =============================================================

# Supabase (Optional - enter in Settings panel instead)
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=

# Google Drive (Optional - enter in Settings panel instead)
# VITE_GOOGLE_DRIVE_CLIENT_ID=
# VITE_GOOGLE_DRIVE_FOLDER_ID=
